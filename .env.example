# API key(s) for this benchmark service
BENCH_API_KEYS=change-me
BENCH_API_KEY_HEADER=X-API-Key

# FoxNose connection
FOXNOSE_BASE_URL=https://api.foxnose.net
FOXNOSE_ENV_KEY=
FOXNOSE_AUTH_MODE=secure
FOXNOSE_PUBLIC_KEY=
FOXNOSE_PRIVATE_KEY=
# FOXNOSE_SECRET_KEY=   # for auth_mode=simple
# FOXNOSE_ACCESS_TOKEN= # for auth_mode=jwt

# FoxNose folder aliases/keys
FOXNOSE_BENCH_JOBS_FOLDER=benchmark_jobs
FOXNOSE_BENCH_REPORTS_FOLDER=benchmark_reports
FOXNOSE_BENCH_REPORT_ITEMS_FOLDER=benchmark_report_items

# Datasets
# Local run can point to datasets.open_track.json (recommended).
# Docker compose overrides this to /app/config/datasets.docker.json.
BENCH_DATASETS_FILE=./config/datasets.open_track.json
BENCH_DATASETS_ROOT=./data/datasets

# Local runtime dirs
BENCH_WORK_DIR=./data/work
BENCH_REPORTS_DIR=./data/reports
BENCH_VENV_ROOT=./data/venvs
